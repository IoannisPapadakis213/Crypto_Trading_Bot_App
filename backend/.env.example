# CoinGecko free tier works without a key. Set this only if you have a
# Demo/Pro API key and want a higher rate limit.
COINGECKO_API_KEY=

COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# sqlite+aiosqlite:///... by default (see app/core/config.py); point this at
# a Postgres URL later with no code changes required.
DATABASE_URL=

MARKET_UNIVERSE_SIZE=100
RANKING_TOP_N=10
PIPELINE_INTERVAL_MINUTES=15
MIN_SNAPSHOTS_FOR_VOLUME_AVG=4

CANDLE_EXCHANGE_ID=kraken
CANDLE_TIMEFRAME=1h

# Comma-separated list of origins allowed to call this API from a browser.
CORS_ORIGINS=http://localhost:3000,https://crypto-trading-bot-app.vercel.app
